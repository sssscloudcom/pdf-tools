/*
  Content Security Policy Headers
  https://pdftools.nextapi.pro
  
  Generated: 2026-06-24
*/

/*
  Default: only allow same-origin
*/
Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https:; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

/*
  Prevent clickjacking
*/
X-Frame-Options: DENY

/*
  Prevent MIME sniffing
*/
X-Content-Type-Options: nosniff

/*
  Enable XSS filter
*/
X-XSS-Protection: 1; mode=block

/*
  Referrer policy
*/
Referrer-Policy: strict-origin-when-cross-origin

/*
  Permissions policy
*/
Permissions-Policy: camera=(), microphone=(), geolocation=()

/*
  Strict Transport Security (HSTS)
*/
Strict-Transport-Security: max-age=31536000; includeSubDomains; preload